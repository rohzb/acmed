# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Runtime state for local acmed runs
# (matches config.example.yml defaults)
data/
*.sqlite3
*.db
*.log

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local env files
docker/.env
docker/config/config.yml
docker/secrets/*
!docker/secrets/.gitkeep
