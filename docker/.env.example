# Copy to docker/.env and adjust IDs if needed.
# For exact host values, run:
#   id -u
#   id -g
ACMED_UID=10001
ACMED_GID=10001

# Bind host interface/port for published service.
# Use 0.0.0.0 for host-wide/public exposure or 127.0.0.1 for loopback-only.
ACMED_PUBLISH_IP=0.0.0.0
ACMED_PUBLISH_PORT=8443

# Host paths used by compose for persistent data and admin token secret.
# Can be relative (to docker/) or absolute.
ACMED_DATA_DIR=./data
ACMED_ADMIN_TOKEN_FILE=./secrets/acmed_token_admin

# Optional acme.sh ref for issuer-enabled image targets.
ACMESH_REF=master
